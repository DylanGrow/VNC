# VNC Server Settings
HOST=0.0.0.0
PORT=8000

# Authentication (JWT)
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=change_this_to_a_very_secure_random_string_at_least_32_bytes_long
ACCESS_TOKEN_EXPIRE_MINUTES=15
SECURE_PASSWORD=your_secure_password

# SSL Configuration (Optional for development, recommended for production)
# SSL_KEYFILE=path/to/key.pem
# SSL_CERTFILE=path/to/cert.pem

# Connection Limits
MAX_CONNECTIONS_PER_IP=3
MAX_GLOBAL_CONNECTIONS=10

# Capture Settings
DEFAULT_QUALITY=75
DEFAULT_FPS=30
