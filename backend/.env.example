# Environment variables for Antigravity VNC System
# Copy this file to .env and fill in real values before deploying.

# --- Authentication ---
# A strong password for accessing the VNC console
SECURE_PASSWORD=change_me_to_a_strong_password

# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_very_secure_random_key_at_least_32_bytes

# JWT token lifetime in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# --- Audit Log Encryption ---
# AES-256-GCM key for encrypting audit log entries (base64-encoded 32-byte key)
# Generate with: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
AUDIT_LOG_KEY=

# --- Server Network ---
HOST=0.0.0.0
PORT=8000

# --- SSL (optional, required for production) ---
# Set AUTO_SSL=true to generate a self-signed cert automatically
AUTO_SSL=false
SSL_CERT_FILE=
SSL_KEY_FILE=

# --- Environment Mode ---
# Set to "production" to enforce secure cookie flags and stricter checks
ENV=development

# --- Connection Limits ---
MAX_CONNECTIONS_PER_IP=3
MAX_GLOBAL_CONNECTIONS=10

# --- File Upload ---
# Maximum file upload size in megabytes (default: 100)
MAX_UPLOAD_SIZE_MB=100

# --- CORS ---
# Comma-separated list of allowed origins for production (e.g. https://vnc.yourdomain.com)
# Leave empty to restrict to localhost only
ALLOWED_ORIGINS=

# --- Frontend ---
# Path to the compiled Vite dist directory (optional override)
FRONTEND_DIST_PATH=
